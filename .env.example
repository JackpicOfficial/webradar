# WebRadar — Environment Configuration
# Copy this file to .env and fill in your values

PORT=3000
NODE_ENV=development

# ── PageSpeed Insights API key (optional but recommended) ──────────────────
# Without a key: 400 requests/day (shared Google quota — hits limit quickly).
# With a free key: 25,000 requests/day.
#
# Get yours free in ~2 minutes:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a project → Enable "PageSpeed Insights API"
#   3. Create Credentials → API Key → copy it below
#
# PAGESPEED_KEY=your_key_here
